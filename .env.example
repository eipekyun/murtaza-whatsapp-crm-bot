# PoC güvenli varsayılanlar
BOT_TENANT_ID=esmark-test
BOT_DISPLAY_NAME=ESMARK Asistan
BOT_DB_PATH=./data/poc.sqlite
BOT_AUTH_DIR=./data/auth/esmark-test
BOT_WHITELIST_PHONES=905551112233,905559998877
BOT_AUTO_REPLY=true
# Operatör paneli HTTP auth token. Boş bırakılırsa data/operator-token.txt
# içinde otomatik üretilir (chmod 600). Min 16 karakter.
BOT_OPERATOR_TOKEN=

# --- Gelen medya arşivleme (firma Drive klasörüne kaydet) ---
# Gelen medyayı firma Drive klasörüne arşivle (true/false). Default true.
BOT_ARCHIVE_MEDIA=true
# Arşivlenecek medya türleri (csv): image,video,document,audio,sticker. Default image,video,document,audio.
BOT_ARCHIVE_MEDIA_KINDS=image,video,document,audio
# Gelen medya için indirme üst sınırı (MB). Aşan medya indirilmez, status=skipped olur. Default 50.
BOT_MAX_MEDIA_MB=50
# Gelen medyanın indirileceği geçici dizin. Default <dataDir>/media/incoming.
BOT_MEDIA_INCOMING_DIR=
# Drive upload script'ini çalıştıracak Python. Default hermes-agent pipx venv python3.
BOT_DRIVE_PYTHON=
# Drive upload script yolu. Default <cwd>/scripts/wa_drive_upload.py.
BOT_DRIVE_UPLOAD_SCRIPT=
# Drive OAuth token dosyası (sadece PATH; gerçek token değeri buraya yazılmaz). Default ~/.hermes/drive_token.json.
BOT_DRIVE_TOKEN_PATH=
# Müşteri kartları dizini (slug.md). Default <cwd>/../../01-Musteriler (vault).
BOT_CUSTOMERS_DIR=
